{
  "expo": {
    "name": "Vector",
    "slug": "vector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vector",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A1B",
    "ios": {
      "bundleIdentifier": "ro.divex.vector",
      "supportsTablet": false,
      "userInterfaceStyle": "dark"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A1B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Deblochează Vector cu Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vector accesează pozele pentru a scana bonuri.",
          "cameraPermission": "Vector folosește camera pentru a fotografia și scana bonuri."
        }
      ],
      "./plugins/with-disable-script-sandboxing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
