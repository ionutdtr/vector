# Vector — environment variables (copy to .env, never commit real values)

# Neon (backend + db package)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Anthropic (backend only — never in the mobile app). Needed for Phase 3 (AI).
ANTHROPIC_API_KEY=sk-ant-...

# Self-hosted auth (backend only). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Mobile → API base URL (LAN IP of your Mac for a physical iPhone)
EXPO_PUBLIC_API_URL=http://localhost:3000
