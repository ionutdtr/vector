# Vector — environment variables (copy to .env, never commit real values)

# Neon (backend + db package)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Anthropic (backend only — never in the mobile app). Needed for Phase 3 (AI).
ANTHROPIC_API_KEY=sk-ant-...

# Transactional email (backend only) for verification + password-reset codes.
# Without RESEND_API_KEY the codes are logged to the server (fine for local dev).
# RESEND_API_KEY=re_...
# EMAIL_FROM=Vector <no-reply@your-domain.com>


# Self-hosted auth (backend only). REQUIRED in production: a random string of at
# least 32 characters. The API refuses to boot in production without a strong one
# (a predictable secret lets anyone forge a token for any user). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Set to "production" on the deployed API so security fail-safes (JWT_SECRET
# check, etc.) are enforced. Leave unset locally.
# NODE_ENV=production

# CORS allow-list for the API (comma-separated origins). Optional: only needed if
# a browser client calls the API. The native mobile app sends no Origin and needs
# no entry here. Leave unset to allow all origins (fine for a token-only mobile API).
# CORS_ORIGINS=https://app.vector.app,https://vector.app

# Mobile → API base URL. Local dev: LAN IP of your Mac for a physical iPhone.
# Production builds set this per-profile in apps/mobile/eas.json (HTTPS only).
EXPO_PUBLIC_API_URL=http://localhost:3000
