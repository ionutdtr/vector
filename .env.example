# Vector — environment variables (copy to .env, never commit real values)

# Neon (backend + db package)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Anthropic (backend only — never in the mobile app)
ANTHROPIC_API_KEY=sk-ant-...

# Neon Auth (Stack Auth) — public keys go to the mobile app, secret stays server-side
NEON_AUTH_PROJECT_ID=
NEON_AUTH_PUBLISHABLE_CLIENT_KEY=
NEON_AUTH_SECRET_SERVER_KEY=

# Mobile → API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000
